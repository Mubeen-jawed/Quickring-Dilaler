# ── QuickRing production environment ────────────────────
# Copy this to ".env" on the VPS and fill in the real values.
# (deploy/deploy.sh will create .env from this file and auto-generate the
#  JWT secrets for you if .env does not already exist.)

# ── Server ──────────────────────────────────────────────
PORT=3002
NODE_ENV=production
# Public HTTPS URL — used to build Twilio status/recording callback URLs.
SERVER_BASE_URL=https://dialer.revenuelyft.com

# ── Database (Neon Postgres) ────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# ── Auth secrets (auto-generated by deploy.sh) ──────────
JWT_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me

# ── Twilio (required for real calls) ────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_twilio_api_secret
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+10000000000

# ── Misc ────────────────────────────────────────────────
RATE_PER_MINUTE=0
